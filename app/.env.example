# Copy to .env.local to run against real Solana devnet + Ephemeral Rollups.
# Leave unset (or VITE_MODE=demo) to run the instant local simulation.

VITE_MODE=onchain
VITE_PROGRAM_ID=BmDc7HBxBt5bZLFz6UJ24mdHYr7DQfFw7eSnpo3HamQ6
VITE_ROUTER_RPC=https://devnet-router.magicblock.app
VITE_BASE_RPC=https://api.devnet.solana.com

# Optional: extra failover RPC for solana-resilience-kit (e.g. your QuickNode devnet URL).
VITE_QUICKNODE_RPC=
